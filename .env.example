# Database Configuration
# Set DATABASE_PROVIDER to 'postgres' (or 'postgresql') to use PostgreSQL, or 'json' (or leave empty) for JSON file storage
DATABASE_PROVIDER=json

# PostgreSQL Connection String (only needed when DATABASE_PROVIDER=postgres)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
# Example: postgresql://postgres:password@localhost:5432/gmanimato?schema=public
DATABASE_URL=

# S3 configuration (used by server-side upload)
# Example values — create a real .env or set environment vars in your deployment.
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_REGION=us-east-1
RUNPOD_API_KEY=your-api-key
RUNPOD_ENDPOINT_URL=video-endpoint-url
# Optional: custom S3 endpoint (for MinIO/local stacks), e.g. http://localhost:9000
S3_ENDPOINT=

# Custom VL endpoint (optional - used for image recognition)
# Production uses explicit auth mode (no auto detection).
# Valid values: modal | cf | custom | bearer | none
CUSTOM_VL_URL=
CUSTOM_VL_AUTH_MODE=none
CUSTOM_VL_TOKEN_ID=
CUSTOM_VL_TOKEN_SECRET=
CUSTOM_VL_TOKEN_ID_HEADER=
CUSTOM_VL_TOKEN_SECRET_HEADER=
# Route recognition to Modal fallback when local queue is busy.
CUSTOM_VL_ROUTE_MODAL_WHEN_LOCAL_BUSY=false
# Busy threshold uses: in_queue + processing > threshold.
CUSTOM_VL_LOCAL_BUSY_THRESHOLD=0
# Optional Modal fallback endpoint (used only when routing is enabled and busy threshold is exceeded).
CUSTOM_VL_MODAL_FALLBACK_URL=
CUSTOM_VL_MODAL_FALLBACK_TOKEN_ID=
CUSTOM_VL_MODAL_FALLBACK_TOKEN_SECRET=
CUSTOM_VL_API_KEY=
CUSTOM_VL_MODEL=
CUSTOM_VL_MAX_TOKENS=1024
CUSTOM_VL_ENABLE_THINKING=false
CUSTOM_VL_TIMEOUT_MS=60000

# Set to 'true' to inject PathchSageAttentionKJ nodes into generated workflows.
# Requires the sageattention package to be installed on the target ComfyUI workers.
# RUNPOD: controls workflows pushed to RunPod serverless workers.
# LOCAL: controls workflows served to local polling workers (api/worker/task).
ENABLE_SAGE_ATTENTION_RUNPOD=false
ENABLE_SAGE_ATTENTION_LOCAL=false
