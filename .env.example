# Database Configuration
# Set DATABASE_PROVIDER to 'postgres' (or 'postgresql') to use PostgreSQL, or 'json' (or leave empty) for JSON file storage
DATABASE_PROVIDER=json

# PostgreSQL Connection String (only needed when DATABASE_PROVIDER=postgres)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
# Example: postgresql://postgres:password@localhost:5432/gmanimato?schema=public
DATABASE_URL=

# S3 configuration (used by server-side upload)
# Example values — create a real .env or set environment vars in your deployment.
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_REGION=us-east-1
RUNPOD_API_KEY=your-api-key
RUNPOD_ENDPOINT_URL=video-endpoint-url
# Optional: custom S3 endpoint (for MinIO/local stacks), e.g. http://localhost:9000
S3_ENDPOINT=

# Custom VL endpoint (optional - used for image recognition)
# Option A — Modal.com direct endpoint (recommended):
#   Set CUSTOM_VL_URL to your Modal endpoint URL
#   Set CUSTOM_VL_MODAL_TOKEN_ID and CUSTOM_VL_MODAL_TOKEN_SECRET from https://modal.com/settings/proxy-auth-tokens
# Option B — OpenAI-compatible endpoint (e.g. RunPod, local vLLM):
#   Set CUSTOM_VL_URL to the full URL including path (e.g. https://api.runpod.ai/v2/xxx/openai/chat/completions)
#   Set CUSTOM_VL_API_KEY and CUSTOM_VL_MODEL
CUSTOM_VL_URL=
CUSTOM_VL_MODAL_TOKEN_ID=
CUSTOM_VL_MODAL_TOKEN_SECRET=
CUSTOM_VL_API_KEY=
CUSTOM_VL_MODEL=
CUSTOM_VL_TIMEOUT_MS=60000
